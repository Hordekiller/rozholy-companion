{
  "name": "hordekiller/rozholy-companion",
  "type": "wordpress-plugin",
  "description": "Rozholy companion plugin with Elementor widgets and booking system",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "szepeviktor/phpstan-wordpress": "^2.0"
  },
  "scripts": {
    "phpstan": "vendor/bin/phpstan analyse",
    "phpstan:baseline": "vendor/bin/phpstan analyse --generate-baseline"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
